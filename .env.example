# Copy to .env and fill in, then `export $(cat .env | xargs)` or use a tool like direnv/python-dotenv.

# Capital IQ GDS ("clientservice") REST API credentials.
CIQ_USERNAME=
CIQ_PASSWORD=
# Only needed if your account uses a non-default gateway URL.
# CIQ_API_BASE_URL=https://api.capitaliq.com/gdsapi/rest/v3/clientservice.json

# Required for the free data source (SEC EDGAR + Yahoo Finance, no API key
# needed otherwise). SEC requires a descriptive contact string on every
# request and returns 403 Forbidden without one.
SEC_USER_AGENT="YourApp your@email.com"

# Anthropic API key, used for Factor 2/4/5 qualitative scoring and playbook generation.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional overrides for the WACC (cost of capital) proxy used in Factor 1.
# RISK_FREE_RATE=0.045
# EQUITY_RISK_PREMIUM=0.05
# DEFAULT_TAX_RATE=0.25
